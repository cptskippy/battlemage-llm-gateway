healthCheckTimeout: 180
logLevel: info

models:
  qwen3.6-27b:
    proxy: http://127.0.0.1:9000
    ttl: 600
    cmd: >
      bash -c "source /opt/intel/oneapi/setvars.sh > /dev/null && exec {{LLAMA_SERVER_BIN}}
      -m {{QWEN_GGUF}}
      -ngl 999
      -c 262144
      -ctk q8_0 -ctv q8_0
      -fa on
      --parallel 1
      --host 127.0.0.1 --port 9000
      --jinja
      --alias qwen3.6-27b"

