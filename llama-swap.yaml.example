healthCheckTimeout: 180
logLevel: info

models:
  qwen3.6-27b:
    proxy: http://127.0.0.1:9000
    ttl: 1800
    cmd: >
      bash -c "source /opt/intel/oneapi/setvars.sh > /dev/null && exec /home/cptskippy/llama.cpp/build/bin/llama-server
      -m /home/cptskippy/.lmstudio/models/lmstudio-community/Qwen3.6-27B-GGUF/Qwen3.6-27B-Q4_K_M.gguf
      -ngl 999
      -c 65536
      -ctk q8_0 -ctv q8_0
      -fa on
      --parallel 1
      --host 127.0.0.1 --port 9000
      --jinja
      --alias qwen3.6-27b
      --verbose
      2>> /home/cptskippy/.llama-server-qwen.log"

  gemma-4-31b:
    proxy: http://127.0.0.1:9000
    ttl: 1800
    cmd: >
      bash -c "source /opt/intel/oneapi/setvars.sh > /dev/null && exec /home/cptskippy/llama.cpp/build/bin/llama-server
      -m /home/cptskippy/.lmstudio/models/lmstudio-community/gemma-4-31B-it-GGUF/gemma-4-31B-it-Q4_K_M.gguf
      -ngl 999
      -c 65536
      -ctk q8_0 -ctv q8_0
      -fa on
      --parallel 1
      --host 127.0.0.1 --port 9000
      --jinja
      --alias gemma-4-31b
      --verbose
      2>> /home/cptskippy/.llama-server-gemma.log"

  deepseek-r1-32b:
    proxy: http://127.0.0.1:9000
    ttl: 1800
    cmd: >
      bash -c "source /opt/intel/oneapi/setvars.sh > /dev/null && exec /home/cptskippy/llama.cpp/build/bin/llama-server
      -m /home/cptskippy/.lmstudio/models/lmstudio-community/DeepSeek-R1-Distill-Qwen-32B-GGUF/DeepSeek-R1-Distill-Qwen-32B-Q4_K_M.gguf
      -ngl 999
      -c 65536
      -ctk q8_0 -ctv q8_0
      -fa on
      --parallel 1
      --host 127.0.0.1 --port 9000
      --jinja
      --alias deepseek-r1-32b
      --verbose
      2>> /home/cptskippy/.llama-server-deepseek.log"

  qwen3.6-27b-thinker:
    proxy: http://127.0.0.1:9000
    ttl: 1800
    cmd: >
      bash -c "source /opt/intel/oneapi/setvars.sh > /dev/null && exec /home/cptskippy/llama.cpp/build/bin/llama-server
      -m /home/cptskippy/.lmstudio/models/lmstudio-community/Qwen3.6-27B-GGUF/Qwen3.6-27B-Q6_K.gguf
      -ngl 999
      -c 65536
      -ctk q8_0 -ctv q8_0
      -fa on
      --parallel 1
      --temp 0.2
      --min-p 0.05
      --repeat-penalty 1.05
      --top-k 0
      --top-p 1.0
      --host 127.0.0.1 --port 9000
      --jinja
      --alias qwen3.6-27b-thinker
      --verbose
      2>> /home/cptskippy/.llama-server-qwen-thinker.log"

  hermes-4-14b:
    proxy: http://127.0.0.1:9001
    ttl: 0
    cmd: >
      bash -c "source /opt/intel/oneapi/setvars.sh > /dev/null && exec /home/cptskippy/llama.cpp/build/bin/llama-server
      -m /home/cptskippy/.lmstudio/models/hermes-4-14b/Hermes-4-14B-Q4_K_S.gguf
      -ngl 999
      -c 16384
      -ctk q8_0 -ctv q8_0
      -fa on
      --parallel 1
      --host 127.0.0.1 --port 9001
      --jinja
      --alias hermes-4-14b
      --verbose
      2>> /home/cptskippy/.llama-server-hermes.log"

groups:
  port9000:
    swap: true        # only one of these loaded at a time
    exclusive: false  # loading one of these does NOT unload other groups
    members:
      - "qwen3.6-27b"
      - "gemma-4-31b"
      - "deepseek-r1-32b"
      - "qwen3.6-27b-thinker"

  port9001:
    persistent: true  # other groups can't unload this one
    swap: true        # only one of these loaded at a time
    exclusive: false  # loading this doesn't unload big-models
    members:
      - "hermes-4-14b"
